# --- HarmonyOS build outputs ---
# Note: /build/ contains committed source (build scripts, vite config).
# Only ignore HarmonyOS build outputs and electerm-web build artifacts.
/build/outputs/
/build/intermediates/
/oh_modules/
/entry/build/
/web_engine/build/
/.hvigor/
/.cache/
/.cxx/

# --- Signing materials (NEVER commit) ---
/signing/*
!/signing/.gitkeep
*.p12
*.cer
*.p7b
*.csr

# --- Electron runtime (downloaded by prepare-electron-runtime.sh, not committed) ---
# web_engine/ is the entire HAR module from the prebuilt tarball
/web_engine/
# .so libraries extracted from the tarball
/entry/libs/

# --- Generated build-profile.json5 (generated by build-app.sh) ---
/build-profile.json5

# --- electerm build output ---
/work/
/build/harmony/resfile/
/.env
/dist/

# --- Node.js ---
node_modules/

# --- IDE ---
.idea/
.vscode/
*.iml

# --- OS ---
.DS_Store
Thumbs.db

# --- Temp ---
/temp/
# Build download cache
/build-download/
build/harmony/rawfile
src/client/electerm-react/
entry/src/main/resources/rawfile
/src/client