/build-profile.json5

# --- electerm-web build output ---
/electerm-web/build/harmony/resfile/
/electerm-web/node_modules/
/electerm-web/.env
/electerm-web/dist/

# --- Node.js ---
node_modules/

# --- IDE ---
.idea/
.vscode/
*.iml

# --- OS ---
.DS_Store
Thumbs.db

# --- Temp ---
/temp/
